# StellarHydra environment template — copy to .env and fill in values.

# StellarRoute API (local default matches StellarRoute docker-compose)
STELLARROUTE_API_URL=http://localhost:8080
STELLARROUTE_TIMEOUT_SECONDS=15

# Redis (cache + Celery broker)
REDIS_URL=redis://localhost:6379/0
HYDRA_REDIS_KEY_PREFIX=hydra:
HYDRA_SIGNAL_TTL_SECONDS=300

# Drips Wave API
DRIPS_API_URL=https://api.drips.network
DRIPS_API_KEY=
DRIPS_DRY_RUN=true

# Hydra policy
HYDRA_MAX_DRIP_XLM_PER_HOUR=1000
HYDRA_SLIPPAGE_ALERT_BPS=100
HYDRA_PREDICTION_HORIZON_MINUTES=30
HYDRA_WATCHLIST=native:USDC,USDC:native

# LangGraph
HYDRA_CHECKPOINT_THREAD_PREFIX=cycle-

# Admin API (Phase 3)
HYDRA_API_HOST=0.0.0.0
HYDRA_API_PORT=8090
HYDRA_ADMIN_API_KEY=change-me-in-production

# Observability
HYDRA_LOG_LEVEL=INFO
HYDRA_ENABLE_OTEL=false
OTEL_EXPORTER_OTLP_ENDPOINT=

# Celery
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2
